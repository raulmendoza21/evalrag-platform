# Backend goes here

Recommended structure (build incrementally — do not pre-create empty files):

app/
  api/        routes_documents.py, routes_chat.py, routes_evaluation.py, routes_metrics.py, routes_health.py
  services/   ingestion, chunking, embedding, retrieval, reranking, generation, guardrails, evaluation, rag_pipeline
  repositories/  document, chunk, conversation, metrics
  infrastructure/  postgres, qdrant, redis, llm_client, embedding_client, storage
  schemas/    document, chat, evaluation, metrics
  prompts/    rag_answer, query_rewrite, guardrail, evaluation
  tests/
migrations/   001_initial_schema.sql
